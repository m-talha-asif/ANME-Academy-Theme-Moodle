    {{#js}}
require(['jquery'], function($) {
    $(document).ready(function() {
        var gearMenu = '.academy-gear-menu';
        var settingsDropdown = '.academy-settings-dropdown';
        var moreButton = '[data-region="morebutton"] > a, .dropdownmoremenu > a';

        $(settingsDropdown).on('click', moreButton, function(e) {
            e.preventDefault(); 
            e.stopPropagation(); 
            var $parentLi = $(this).parent();
            var $nestedMenu = $parentLi.children('.dropdown-menu');
            if ($parentLi.hasClass('show')) {
                $parentLi.removeClass('show');
                $nestedMenu.removeClass('show');
                $(this).attr('aria-expanded', 'false');
            } else {
                $parentLi.addClass('show');
                $nestedMenu.addClass('show');
                $(this).attr('aria-expanded', 'true');
            }
        });
        
        $(gearMenu).on('hidden.bs.dropdown', function () {
            var $moreContainer = $(this).find('[data-region="morebutton"], .dropdownmoremenu');
            var $moreLink = $moreContainer.find('> a');
            var $moreMenu = $moreContainer.find('.dropdown-menu');
            $moreContainer.removeClass('show');
            $moreMenu.removeClass('show');
            $moreLink.attr('aria-expanded', 'false');
        });
        
        $(settingsDropdown).on('click', '.dropdown-menu', function(e) {
            e.stopPropagation();
        });
    });
});
{{/js}}
